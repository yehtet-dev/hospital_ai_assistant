    {
      "parameters": {
        "jsCode": "const r = $input.first().json.body;\nconst parseDate = (raw) => {\n  if (!raw) return $today.toFormat('yyyy-MM-dd');\n  if (DateTime.fromISO(raw).isValid) return DateTime.fromISO(raw).toFormat('yyyy-MM-dd');\n  if (DateTime.fromFormat(raw, 'yyyy-MM-dd').isValid) return raw;\n  if (DateTime.fromFormat(raw, 'M/d/yyyy').isValid) return DateTime.fromFormat(raw, 'M/d/yyyy').toFormat('yyyy-MM-dd');\n  if (DateTime.fromFormat(raw, 'dd/MM/yyyy').isValid) return DateTime.fromFormat(raw, 'dd/MM/yyyy').toFormat('yyyy-MM-dd');\n  return $today.toFormat('yyyy-MM-dd');\n};\nreturn [{\n  json: {\n    patientName: (r.Full_Name || '').toString().trim(),\n    phone: (r.Phone_Number || '').toString(),\n    symptom: (r.Primary_Symptom || '').toString(),\n    doctorName: (r.Doctor_Name || '').toString().trim(),\n    appointmentDate: parseDate(r.Appointment_Date || r.Date),\n    chatId: (r.Chat_ID || '').toString(),\n    Age: (r.Age || '').toString(),\n    Sex: (r.Sex || '').toString(),\n    Address: (r.Address || '').toString(),\n    Visit_Type: (r.Visit_Type || 'New').toString(),\n    Timestamp: $now.toFormat('yyyy-MM-dd HH:mm:ss')\n  }\n}];\n"
      },
