    {
      "parameters": {
        "jsCode": "const req = $('Prepare Data').first().json;\nconst doctorItems = $('Find Doctor').all().filter(i => i.json.Doctor_Name);\n\nif (doctorItems.length === 0) {\n  return [{ json: { decision: 'REJECT', output: `Status: DOCTOR_NOT_FOUND. No doctor named '${req.doctorName}' exists.` } }];\n}\n\nconst doc = doctorItems[0].json;\nconst days = (doc.Available_Days || '').toString().split(',').map(s => s.trim()).filter(Boolean);\nconst hours = doc.Available_Time || 'N/A';\nconst maxPerDay = doc.max_patients_per_day || 20;\n\n// NEW LOGIC: Split the Live_Queue column by commas and count the length\nconst liveQueueArr = (doc.Live_Queue || '').toString().split(',').filter(Boolean);\nconst count = liveQueueArr.length;\n\nconst weekdayOf = ds => new Date(ds + 'T00:00:00Z').toLocaleDateString('en-US', { weekday: 'long', timeZone: 'UTC' });\nconst nextAvailable = from => {\n  const d = new Date(from + 'T00:00:00Z');\n  for (let i = 1; i <= 14; i++) {\n    d.setUTCDate(d.getUTCDate() + 1);\n    const iso = d.toISOString().slice(0, 10);\n    if (days.includes(weekdayOf(iso))) return iso;\n  }\n  return null;\n};\n\nif (!days.includes(weekdayOf(req.appointmentDate))) {\n  return [{ json: { ...req, decision: 'REJECT', output: `Status: DOCTOR_UNAVAILABLE. ${doc.Doctor_Name} is only available on ${days.join(', ')} (${hours}). Suggested Date: ${nextAvailable(req.appointmentDate) || 'none found'}` } }];\n}\n\n// Evaluate using the new Live_Queue count\nif (count >= maxPerDay) {\n  return [{ json: { ...req, decision: 'REJECT', output: `Status: SLOT_FULL. ${doc.Doctor_Name} is fully booked on ${req.appointmentDate}. Suggested Date: ${nextAvailable(req.appointmentDate) || 'none found'}` } }];\n}\n\nreturn [{ json: { ...req, decision: 'BOOK', doctorName: doc.Doctor_Name, hours, tokenNumber: count + 1 } }];"
      },
