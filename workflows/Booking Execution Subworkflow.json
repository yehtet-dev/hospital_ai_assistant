    {
      "parameters": {
        "jsCode": "const p = $input.first().json;\nconst patientId = 'P-' + $now.toFormat('yyyyMMddHHmmss') + '-' + $now.toFormat('SSS');\nconst triageUrl = 'https://docs.google.com/forms/d/e/1FAIpQLSclqggNnB0sAmgqRg6gdiA7Gia7RWxuMbZVjeoF9G0JMDj7Kg/viewform?usp=pp_url&entry.347884731=' + encodeURIComponent(patientId);\nconst qrUrl = 'https://quickchart.io/qr?text=' + encodeURIComponent(triageUrl) + '&size=300&margin=2';\nreturn [{\n  json: {\n    ...p,\n    Timestamp: $now.toFormat('yyyy-MM-dd HH:mm:ss'),\n    Patient_ID: patientId,\n    Full_Name: p.patientName,\n    Phone_Number: p.phone,\n    Primary_Symptom: p.symptom,\n    Doctor_Name: p.doctorName,\n    Date: p.appointmentDate,\n    Chat_ID: p.chatId,\n    Token_Number: p.tokenNumber,\n    Status: 'Scheduled',\n    Triage_Form_URL: triageUrl,\n    QR_Image_URL: qrUrl,\n    Age: p.Age || '',\n    Sex: p.Sex || '',\n    Address: p.Address || '',\n    Visit_Type: p.Visit_Type || 'New'\n  }\n}];\n"
