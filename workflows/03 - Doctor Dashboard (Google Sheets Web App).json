      "parameters": {
        "jsCode": "const input = $input.first().json;\n// Get Current Queue \nlet current_queue = $input.first().json.Current_Queue_Number;\n// Get Patient Token\nlet patient_token = $('Read Patient').first().json.Token_Number;\n// Check if current queue = patient token\n// if not equal means there is missed turn\n\nif (current_queue !== patient_token) {\n  current_queue = patient_token\n} else {\n  current_queue = current_queue\n}\n\nreturn {\n  row_number: input.row_number,\n  Id: input.Id,\n  Doctor_Name: input.Doctor_Name,\n  Current_Queue_Number: current_queue,\n  Notes: input.Notes,\n  Date: input.Date\n};"
