    {
      "parameters": {
        "jsCode": "\nconst patient = $('Read Patient').first().json;\nconst queueItems = $('Update Queue Number').all();\nconst queue = queueItems.length ? queueItems[0].json : {};\nconst patients = $input.all().map(i => i.json).filter(r => r && r.Token_Number != null && r.Status === 'Checked-in');\n\nconst token = Number(patient.Token_Number) || 0;\nlet currentQueue = queue.Current_Queue_Number ? Number(queue.Current_Queue_Number) : NaN;\nif (isNaN(currentQueue)) currentQueue = token;\nconst newQueue = currentQueue + 1;\n\nconst avgTime = Number($(\"Get Doctor's Average Time\").first().json.Avg_Time) || 15;\nconst patientsFor30 = Math.ceil(30 / avgTime);\nconst patientsFor60 = Math.ceil(60 / avgTime);\nconst token30 = newQueue + patientsFor30;\nconst token60 = newQueue + patientsFor60;\n\nconst byToken = {};\npatients.forEach(p => { byToken[Number(p.Token_Number) || 0] = p; });\n\nconst turnPatient = byToken[newQueue] || null;\nconst alert30Patient = byToken[token30] || null;\nconst alert60Patient = byToken[token60] || null;\n\nreturn [{\n  json: {\n    newQueue,\n    token30,\n    token60,\n    avgTime,\n    doctor: patient.Doctor_Name,\n    date: patient.Date,\n    submittedPatientName: patient.Full_Name,\n    patientId: patient.Patient_ID,\n    turnPatient,\n    turnPatientFound: !!turnPatient,\n    turnToken: turnPatient ? Number(turnPatient.Token_Number) : null,\n    alert30Patient,\n    alert30Found: !!alert30Patient,\n    alert30PatientName: alert30Patient ? alert30Patient.Full_Name : null,\n    alert60Patient,\n    alert60Found: !!alert60Patient,\n    alert60PatientName: alert60Patient ? alert60Patient.Full_Name : null\n  }\n}];\n"
      },
