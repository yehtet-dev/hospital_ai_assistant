    {
      "parameters": {
        "jsCode": "\nconst data = $('Compute Next Queue').first().json;\nlet msg = 'Completed ' + data.submittedPatientName + '.';\nif (data.turnPatientFound) {\n  msg += ' Token #' + data.turnToken + ' (' + data.turnPatientName + ') called for Dr. ' + data.doctor + '.';\n} else {\n  msg += ' No more checked-in patients for Dr. ' + data.doctor + '.';\n}\nif (data.alert30Found) msg += ' 30min alert sent to ' + data.alert30PatientName + '.';\nif (data.alert60Found) msg += ' 60min alert sent to ' + data.alert60PatientName + '.';\n\nreturn [{\n  json: {\n    success: true,\n    message: msg,\n    nextToken: data.turnToken || null,\n    nextPatientName: data.turnPatientName || null,\n    token30: data.token30,\n    token60: data.token60\n  }\n}];\n"
      },
